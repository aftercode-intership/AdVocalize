# ============================================================================
# DATABASE (PostgreSQL with pgvector)
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=vocalize
DB_PASSWORD=localpassword
DB_NAME=vocalize_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ============================================================================
# REDIS (Cache & Queue)
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# MINIO (S3-compatible Storage)
# ============================================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false
MINIO_BUCKET_AUDIO=vocalize-audio
MINIO_BUCKET_VIDEOS=vocalize-videos
MINIO_BUCKET_VOICES=vocalize-voices
MINIO_BUCKET_INVOICES=vocalize-invoices
MINIO_BUCKET_AVATARS=vocalize-avatars

# ============================================================================
# OBSERVABILITY
# ============================================================================
# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# Prometheus
PROMETHEUS_RETENTION=30d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Loki
LOKI_RETENTION=30d

# ============================================================================
# TRAEFIK (API Gateway)
# ============================================================================
TRAEFIK_API_INSECURE=true
TRAEFIK_DASHBOARD_ENABLED=true

# ============================================================================
# API CONFIGURATION (for backend when added)
# ============================================================================
API_PORT=8081
API_HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=debug

# ============================================================================
# FRONTEND CONFIGURATION (for Next.js when added)
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================================
# EXTERNAL APIs
# ============================================================================
# GLM API Key (for script generation)
NVIDIA_API_KEY=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
GLM_PROVIDER=nvidia  # "nvidia" or "zhipu" (fallback)
GLM_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
# Stripe (for payments - when added)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
 
# SendGrid (for emails - when added)
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# ============================================================================
# SECURITY & SESSIONS
# ============================================================================
SESSION_SECRET=dev_session_secret_change_in_production
SESSION_TIMEOUT_HOURS=168
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_EXPIRY_HOURS=24

# ============================================================================
# ADMIN USERS
# ============================================================================
ADMIN_USER_IDS=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_VOICE_CLONING=true
FEATURE_VIDEO_GENERATION=true
FEATURE_AFFILIATE_PROGRAM=false
FEATURE_API_WEBHOOKS=false

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_FREE_REQUESTS_PER_MINUTE=10
RATE_LIMIT_PRO_REQUESTS_PER_MINUTE=50
RATE_LIMIT_BURST_MULTIPLIER=2

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM=noreply@vocalize.app
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ============================================================================
# AI SERVICES ENDPOINTS
# ============================================================================
SCRIPT_GEN_SERVICE_URL=http://script-gen:8001
TTS_SERVICE_URL=http://tts:8002
VOICE_CLONE_SERVICE_URL=http://voice-clone:8003
VIDEO_GEN_SERVICE_URL=http://video-gen:8004

# ============================================================================
# DIACRITIZATION (Arabic TTS)
# ============================================================================
DIACRITIZER_MODEL=bert-base-arabic-camelbert-msa-did-madar
DIACRITIZER_CONFIDENCE_THRESHOLD=0.7

# ============================================================================
# MONITORING & ALERTS
# ============================================================================
ALERT_EMAIL=ops@vocalize.app
SLACK_WEBHOOK_URL=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
SEED_DATABASE=false
SEED_TEST_USERS=true
MOCK_EXTERNAL_APIS=false
